# Copy this file to .env and fill in the channels you want to use.
# .env is ignored by git, so tokens and passwords will not be committed.

# Default notification backends for manual runs.
# The Windows scheduled task passes --notify toast,console,wechat,email by default.
OPENUBMC_NOTIFY=toast,console,wechat,email

# WeChat via ServerChan. Create a SENDKEY at https://sct.ftqq.com/
SERVER_CHAN_SENDKEY=

# WeChat via PushPlus. Create a token at https://www.pushplus.plus/
PUSHPLUS_TOKEN=

# Email notifications via SMTP.
# 163 example:
# SMTP_HOST=smtp.163.com
# SMTP_PORT=465
# SMTP_SSL=true
# SMTP_USER=your_account@163.com
# SMTP_PASSWORD=your_smtp_authorization_code
# SMTP_FROM=your_account@163.com
# SMTP_TO=receiver@example.com
SMTP_HOST=
SMTP_PORT=465
SMTP_SSL=true
SMTP_STARTTLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
